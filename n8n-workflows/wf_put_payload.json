Ha újév kezdődött → 001-től, különben +1\n  const newNum = currentYear === lastYear ? lastNum + 1 : 1;\n  newId = `${currentYear}-${String(newNum).padStart(3, '0')}`;\n}\n\nreturn [{ json: { vendeg_id: newId } }];"},"id":"399530c1-3323-446a-ae62-eb705a51d562","name":"Code — Új vendég ID","type":"n8n-nodes-base.code","typeVersion":2,"position":[-352,496]}],"connections":{"Webhook — Form Beküldés":{"main":[[{"node":"Set — Adatok","type":"main","index":0}]]},"Set — Adatok":{"main":[[{"node":"IF — Alkalmas?","type":"main","index":0}]]},"IF — Alkalmas?":{"main":[[{"node":"Code — Nem alkalmas Telegram","type":"main","index":0}],[{"node":"Code — Alkalmas Telegram","type":"main","index":0}]]},"Code — Nem alkalmas Telegram":{"main":[[{"node":"Telegram — Nem alkalmas értesítő","type":"main","index":0}]]},"Code — Alkalmas Telegram":{"main":[[{"node":"Telegram — Alkalmas értesítő","type":"main","index":0}]]},"Telegram — Alkalmas értesítő":{"main":[[{"node":"Code — Email érdeklődőnek","type":"main","index":0}]]},"Code — Email érdeklődőnek":{"main":[[{"node":"Send an Email","type":"main","index":0}]]},"Google Sheets — Leads sor":{"main":[[{"node":"Webhook Response","type":"main","index":0}]]},"Send an Email":{"main":[[{"node":"Google Sheets — Utolsó ID","type":"main","index":0}]]},"Google Sheets — Utolsó ID":{"main":[[{"node":"Code — Új vendég ID","type":"main","index":0}]]},"Code — Új vendég ID":{"main":[[{"node":"Google Sheets — Leads sor","type":"main","index":0}]]}},"settings":{"executionOrder":"v1","errorWorkflow":"HchcRQCllho02oYL"},"staticData":null}
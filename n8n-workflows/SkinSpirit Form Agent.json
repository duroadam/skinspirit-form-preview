    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// ── Új vendég ID generálás ──\n// Input: a Leads sheet összes sora (getAll)\n// A form adatokat a Google Sheets node $('Set — Adatok')-ból húzza majd\n\nconst rows = items;\nconst currentYear = new Date().getFullYear().toString();\n\n// Legutolsó érvényes Vendég ID megkeresése (alulról felfelé)\nlet lastId = '';\nfor (let i = rows.length - 1; i >= 0; i--) {\n  const id = rows[i].json?.['Vendég ID'];\n  if (id && id.toString().includes('-')) {\n    lastId = id.toString().trim();\n    break;\n  }\n}\n\n// Új ID generálás\nlet newId;\nif (!lastId) {\n  // Üres sheet — az első vendég\n  newId = `${currentYear}-001`;\n} else {\n  const parts = lastId.split('-');\n  const lastYear = parts[0];\n  const lastNum = parseInt(parts[1]) || 0;\n  // Ha újév kezdődött → 001-től, különben +1\n  const newNum = currentYear === lastYear ? lastNum + 1 : 1;\n  newId = `${currentYear}-${String(newNum).padStart(3, '0')}`;\n}\n\nreturn [{ json: { vendeg_id: newId } }];"
      },

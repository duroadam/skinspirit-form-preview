      "position": [460, 300]
    },
    {
      "parameters": {
        "operation": "getAll",
        "documentId": { "value": "GOOGLE_SHEETS_DOCUMENT_ID", "__rl": true, "mode": "id" },
        "sheetName": { "value": "Leads", "__rl": true, "mode": "name" },
        "options": {}
      },
      "id": "sheets-get-last-id",
      "name": "Google Sheets — Utolsó ID",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [680, 300],
      "credentials": { "googleSheetsOAuth2Api": { "id": "SHEETS_CREDENTIAL_ID", "name": "Google Sheets" } }
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Új vendég ID generálás\nconst rows = items;\nconst formData = $('Set — CF7 Adatok').item.json;\n\nlet lastId = '';\nfor (let i = rows.length - 1; i >= 0; i--) {\n  const id = rows[i].json?.['Vendég ID'];\n  if (id && id.toString().includes('-')) {\n    lastId = id.toString().trim();\n    break;\n  }\n}\n\nconst currentYear = new Date().getFullYear().toString();\nlet newId;\n\nif (!lastId) {\n  newId = `${currentYear}-001`;\n} else {\n  const parts = lastId.split('-');\n  const lastYear = parts[0];\n  const lastNum = parseInt(parts[1]) || 0;\n  const newNum = currentYear === lastYear ? lastNum + 1 : 1;\n  newId = `${currentYear}-${String(newNum).padStart(3, '0')}`;\n}\n\nreturn [{ json: { ...formData, vendeg_id: newId } }];"
      },
      "id": "code-vendeg-id",
      "name": "Code — Új vendég ID",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [900, 300]
    },
    {
      "parameters": {
        "operation": "append",
        "documentId": { "value": "GOOGLE_SHEETS_DOCUMENT_ID", "__rl": true, "mode": "id" },
        "sheetName": { "value": "Leads", "__rl": true, "mode": "name" },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "Vendég ID":        "={{ $json.vendeg_id }}",
            "Beküldés dátuma":  "={{ $json.bekuldes_datum }}",
            "Vezetéknév":       "",
            "Keresztnév":       "",
            "Név":              "={{ $json.nev }}",
            "Telefon":          "={{ $json.telefon }}",
            "Email":            "={{ $json.email }}",
            "Tárgy":            "={{ $json.targy }}",
            "Üzenet":           "={{ $json.uzenet }}",
            "Forrás":           "={{ $json.forras }}",
            "Státusz":          "Új"
          },
          "schema": []
        },
        "options": {}
      },
      "id": "sheets-append",
      "name": "Google Sheets — CRM sor",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [1120, 300],
      "credentials": { "googleSheetsOAuth2Api": { "id": "SHEETS_CREDENTIAL_ID", "name": "Google Sheets" } }
    },
    {
